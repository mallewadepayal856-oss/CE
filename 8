//Program for Signal to Noise Ratio in dB for PCM

clc;
clear;

//Signal to Noise Ratio in dB for PCM

n = input("Enter the number of bits to encoder: ");

// Formula for non-sinusoidal signal
SNRo = 4.8 + 6*n;

// Note: For a sinusoidal signal, the formula would be:
// SNRo = 1.8 + 6*n;

disp("Output Signal to Noise Ratio in dB for PCM: ");

disp(SNRo);







